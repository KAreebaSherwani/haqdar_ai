GEMINI_API_KEY=your_key_from_aistudio.google.com
# Optional: set this to a Supabase/Postgres pooler URL to persist reports across redeploys.
# Leave blank to use local SQLite. Example: postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
DATABASE_URL=
PRIMARY_MODEL=gemini-3.5-flash
FALLBACK_MODEL=gemini-3.1-flash-lite
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app
